                        <button class="btn btn-outline-success" onclick="importData()">
                            <i class="bi bi-upload"></i> Import Data
                        </button>
                        <button class="btn btn-outline-danger" onclick="clearAllData()">
                            <i class="bi bi-trash"></i> Clear All Data
                        </button>
                        <input type="file" id="importFile" accept=".json" style="display: none;"
                            onchange="handleFileImport()">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function saveToLocalStorage() {
            const data = {
                patients: patients,
                doctors: doctors,
                appointments: appointments,
                departments: departments,
                bills: bills,
                users: users,
                lastUpdated: new Date().toISOString()
            };

            localStorage.setItem('hospitalData', JSON.stringify(data));


            updateStorageIndicator();

            console.log('Data saved to localStorage at', new Date().toLocaleTimeString());
        }


        function loadFromLocalStorage() {
            const savedData = localStorage.getItem('hospitalData');

            if (savedData) {
                try {
                    const data = JSON.parse(savedData);
                    if (data.patients) patients = data.patients;
                    if (data.doctors) doctors = data.doctors;
                    if (data.appointments) appointments = data.appointments;
                    if (data.departments) departments = data.departments;
                    if (data.bills) bills = data.bills;
                    if (data.users) users = data.users;

                    console.log('Data loaded from localStorage');
                    return true;
                } catch (e) {
                    console.error('Error loading data from localStorage:', e);
                    return false;
                }
            }
            return false;
        }


        function initializeDefaultData() {

            const hasData = loadFromLocalStorage();

            if (!hasData) {
                patients = [];
                doctors = [];
                appointments = [];
                departments = [];
                bills = [];


                users = [
                    {
                        name: "Admin User",
                        email: "admin@hospital.com",
                        password: "admin123",
                        phone: "",
                        department: "Administration",
                        joined: new Date().toISOString().split('T')[0]
                    }
                ];

                saveToLocalStorage();
                console.log('Empty data initialized in localStorage');
            }
        }


        function clearAllData() {
            if (confirm('Are you sure you want to delete ALL permanently saved data? This cannot be undone!')) {

                patients = [];
                doctors = [];
                appointments = [];
                departments = [];
                bills = [];


                users = [
                    {
                        name: "Admin User",
                        email: "admin@hospital.com",
                        password: "admin123",
                        phone: "",
                        department: "Administration",
                        joined: new Date().toISOString().split('T')[0]
                    }
                ];


                saveToLocalStorage();


                refreshAllDisplays();


                bootstrap.Modal.getInstance(document.getElementById('storageInfoModal')).hide();

                showAlert('All permanently saved data has been cleared!', 'success');
            }
        }


        function updateStorageIndicator() {
            const indicator = document.querySelector('.storage-indicator');
            if (indicator) {
                const time = new Date().toLocaleTimeString();
                indicator.innerHTML = `<i class="bi bi-database"></i> Saved at ${time}`;
            }
        }


        function showStorageInfo() {

            document.getElementById('storagePatientCount').textContent = patients.length;
            document.getElementById('storageDoctorCount').textContent = doctors.length;
            document.getElementById('storageAppointmentCount').textContent = appointments.length;
            document.getElementById('storageDepartmentCount').textContent = departments.length;
            document.getElementById('storageBillCount').textContent = bills.length;
            document.getElementById('storageUserCount').textContent = users.length;

            const lastBackup = localStorage.getItem('hospitalData')
                ? new Date(JSON.parse(localStorage.getItem('hospitalData')).lastUpdated).toLocaleString()
                : 'Never';
            document.getElementById('lastStorageTime').textContent = lastBackup;

            const modal = new bootstrap.Modal(document.getElementById('storageInfoModal'));
            modal.show();
        }


        function exportAllData() {
            const data = {
                patients: patients,
                doctors: doctors,
                appointments: appointments,
                departments: departments,
                bills: bills,
                users: users,
                exportedAt: new Date().toISOString()
            };

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `hospital_backup_${new Date().toISOString().split('T')[0]}.json`;
            link.click();
            URL.revokeObjectURL(link.href);

            showAlert('Data exported successfully!', 'success');
        }

        function importData() {
            document.getElementById('importFile').click();
        }


        function handleFileImport() {
            const file = document.getElementById('importFile').files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const importedData = JSON.parse(e.target.result);


                    if (importedData.patients) patients = importedData.patients;
                    if (importedData.doctors) doctors = importedData.doctors;
                    if (importedData.appointments) appointments = importedData.appointments;
                    if (importedData.departments) departments = importedData.departments;
                    if (importedData.bills) bills = importedData.bills;
                    if (importedData.users) users = importedData.users;


                    saveToLocalStorage();


                    refreshAllDisplays();

                    showAlert('Data imported successfully!', 'success');


                    bootstrap.Modal.getInstance(document.getElementById('storageInfoModal')).hide();

                } catch (error) {
                    showAlert('Error importing data: Invalid JSON file', 'danger');
                }
            };
            reader.readAsText(file);


            document.getElementById('importFile').value = '';
        }


        function refreshAllDisplays() {
            setCurrentDate();
            updateDashboard();
            renderPatients();
            renderAppointments();
            renderDoctors();
            renderDepartments();
            updateStats();
            populateDropdowns();
            renderBills();
            populatePatientDropdown();
            populateAppointmentPatientDropdown();
            populateDoctorDropdownForPatient();
            renderProfile();
            renderAnalytics();
            updateNavbar();
        }


        function exportData(type) {
            let data = [];
            let filename = '';

            switch (type) {
                case 'patients':
                    data = patients;
                    filename = 'patients';
                    break;
                case 'doctors':
                    data = doctors;
                    filename = 'doctors';
                    break;
                case 'appointments':
                    data = appointments;
                    filename = 'appointments';
                    break;
                default:
                    return;
            }

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `${filename}_backup_${new Date().toISOString().split('T')[0]}.json`;
            link.click();
            URL.revokeObjectURL(link.href);

            showAlert(`${type} exported successfully!`, 'success');
        }


        let patients = [];
        let doctors = [];
        let appointments = [];
        let departments = [];
        let bills = [];


        let users = [
            {
                name: "Admin User",
                email: "admin@hospital.com",
                password: "admin123",
                phone: "",
                department: "Administration",
                joined: new Date().toISOString().split('T')[0]
            }
        ];


        let currentUser = null;


        let appointmentChart, departmentChart, revenueChart, demographicsChart;


        function initializeApp() {

            loadFromLocalStorage();

            setCurrentDate();
            updateDashboard();
            renderPatients();
            renderAppointments();
            renderDoctors();
            renderDepartments();
            updateStats();
            populateDropdowns();
            renderBills();
            populatePatientDropdown();
            populateAppointmentPatientDropdown();
            renderProfile();
            renderAnalytics();
            updateNavbar();


            document.querySelectorAll('.menu-link').forEach(link => {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const section = this.dataset.section;
                    if (section) {
                        switchSection(section);
                    }
                });
            });


            document.querySelectorAll('.nav-link-item').forEach(link => {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const section = this.dataset.section;
                    if (section) {
                        switchSection(section);
                    }
                });
            });


            document.getElementById('patientSearch').addEventListener('input', function (e) {
                const searchTerm = e.target.value.toLowerCase();
                renderPatients(searchTerm);
            });


            const billDateField = document.getElementById('billDate');
            if (billDateField) {
                const today = new Date().toISOString().split('T')[0];
                billDateField.value = today;
            }


            document.getElementById('analyticsDate').textContent = new Date().toLocaleDateString('en-US', {
                weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
            });


            const profileAvatar = document.getElementById('profileAvatar');
            if (profileAvatar) {
                profileAvatar.addEventListener('click', function () {
                    editProfile();
                });
            }


            populateDoctorDropdownForPatient();
        }

        function populateAppointmentPatientDropdown() {
            const select = document.getElementById('appointmentPatient');
            if (select) {
                select.innerHTML = '<option value="">Select Patient</option>' +
                    (patients.length > 0 ? patients.map(p => `<option value="${p.name}">${p.name}</option>`).join('') : '<option value="" disabled>No patients available</option>');
            }
        }

        function populateDoctorDropdownForPatient() {
            const select = document.getElementById('patientDoctor');
            if (select) {
                select.innerHTML = '<option value="">-- Select Doctor --</option>' +
                    (doctors.length > 0 ? doctors.map(d => `<option value="${d.name}">${d.name} (${d.department})</option>`).join('') : '<option value="" disabled>No doctors available</option>');
            }
        }

        function switchSection(section) {
            document.querySelectorAll('.menu-link').forEach(l => l.classList.remove('active'));
            document.querySelectorAll('.nav-link-item').forEach(l => l.classList.remove('active'));

            const sidebarLink = document.querySelector(`.menu-link[data-section="${section}"]`);
            const navbarLink = document.querySelector(`.nav-link-item[data-section="${section}"]`);

            if (sidebarLink) {
                sidebarLink.classList.add('active');
                if (section === 'profile') {
                    sidebarLink.style.transform = 'scale(1.02)';
                    setTimeout(() => {
                        sidebarLink.style.transform = 'scale(1)';
                    }, 200);
                }
            }
            if (navbarLink) navbarLink.classList.add('active');

            document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
            document.getElementById(section).classList.add('active');

            if (section === 'analytics') {
                setTimeout(() => renderAnalytics(), 100);
            }
        }

        function goToHome() {
            switchSection('dashboard');
        }

        function goToProfile() {
            switchSection('profile');
        }

        function editProfile() {
            const modal = new bootstrap.Modal(document.getElementById('editProfileModal'));
            modal.show();
        }

        function updateNavbar() {
            if (currentUser) {
                document.getElementById('navbarUserName').textContent = currentUser.name;
                document.getElementById('navbarAvatar').textContent = currentUser.name.charAt(0).toUpperCase();
            }
        }


        function handleLogin() {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const user = users.find(u => u.email === email && u.password === password);

            if (user) {
                currentUser = user;
                document.getElementById('authContainer').style.display = 'none';
                document.getElementById('mainApp').style.display = 'block';
                initializeApp();
                showAlert(`Welcome back, ${user.name}! Your data is saved permanently.`, 'success');
            } else {
                showAlert('Invalid email or password', 'danger');
            }
        }

        function handleRegister() {
            const name = document.getElementById('regName').value;
            const email = document.getElementById('regEmail').value;
            const password = document.getElementById('regPassword').value;
            const confirm = document.getElementById('regConfirmPassword').value;

            if (!name || !email || !password || !confirm) {
                showAlert('All fields are required', 'danger');
                return;
            }
            if (password !== confirm) {
                showAlert('Passwords do not match', 'danger');
                return;
            }
            if (users.find(u => u.email === email)) {
                showAlert('Email already registered', 'danger');
                return;
            }

            const newUser = {
                name,
                email,
                password,
                phone: "",
                department: "Staff",
                joined: new Date().toISOString().split('T')[0]
            };
            users.push(newUser);


            saveToLocalStorage();

            showAlert('Registration successful! Please login.', 'success');

            document.getElementById('login-tab').click();
            document.getElementById('registerForm').reset();
        }

        function logout() {
            currentUser = null;
            document.getElementById('mainApp').style.display = 'none';
            document.getElementById('authContainer').style.display = 'flex';

            document.getElementById('loginForm').reset();
            document.getElementById('registerForm').reset();

            document.getElementById('login-tab').click();
        }


        function renderProfile() {
            if (!currentUser) return;

            document.getElementById('profileName').textContent = currentUser.name;
            document.getElementById('profileEmail').textContent = currentUser.email;
            document.getElementById('profilePhone').textContent = currentUser.phone || "Not set";
            document.getElementById('profileDepartment').textContent = currentUser.department || "Not set";
            document.getElementById('profileJoined').textContent = currentUser.joined || new Date().toISOString().split('T')[0];

            const avatar = document.getElementById('profileAvatar');
            avatar.textContent = currentUser.name.charAt(0).toUpperCase();

            document.getElementById('editName').value = currentUser.name;
            document.getElementById('editEmail').value = currentUser.email;
            document.getElementById('editPhone').value = currentUser.phone || "";
            document.getElementById('editDepartment').value = currentUser.department || "";
        }

        function updateProfile() {
            if (!currentUser) return;

            currentUser.name = document.getElementById('editName').value;
            currentUser.email = document.getElementById('editEmail').value;
            currentUser.phone = document.getElementById('editPhone').value;
            currentUser.department = document.getElementById('editDepartment').value;

            const userIndex = users.findIndex(u => u.email === currentUser.email);
            if (userIndex !== -1) users[userIndex] = currentUser;

            renderProfile();
            updateNavbar();


            saveToLocalStorage();

            bootstrap.Modal.getInstance(document.getElementById('editProfileModal')).hide();
            showAlert('Profile updated successfully!', 'success');
        }


        function renderAnalytics() {
            const statusCounts = {
                'Scheduled': appointments.filter(a => a.status === 'Scheduled').length,
                'In Progress': appointments.filter(a => a.status === 'In Progress').length,
                'Completed': appointments.filter(a => a.status === 'Completed').length,
                'Cancelled': appointments.filter(a => a.status === 'Cancelled').length
            };

            if (appointmentChart) appointmentChart.destroy();
            const ctx1 = document.getElementById('appointmentChart').getContext('2d');

            const hasAppointmentData = Object.values(statusCounts).some(val => val > 0);

            appointmentChart = new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: hasAppointmentData ? Object.keys(statusCounts).filter(key => statusCounts[key] > 0) : ['No Data'],
                    datasets: [{
                        data: hasAppointmentData ? Object.values(statusCounts).filter(val => val > 0) : [1],
                        backgroundColor: hasAppointmentData ? ['#3498db', '#f39c12', '#2ecc71', '#e74c3c'] : ['#95a5a6']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            const deptNames = departments.map(d => d.name);
            const occupancyData = departments.map(d => d.beds ? ((d.beds - d.availableBeds) / d.beds * 100).toFixed(1) : 0);

            if (departmentChart) departmentChart.destroy();
            const ctx2 = document.getElementById('departmentChart').getContext('2d');
            departmentChart = new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: deptNames.length > 0 ? deptNames : ['No Data'],
                    datasets: [{
                        label: 'Occupancy %',
                        data: deptNames.length > 0 ? occupancyData : [0],
                        backgroundColor: deptNames.length > 0 ? '#667eea' : '#95a5a6'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, max: 100 }
                    }
                }
            });

            if (revenueChart) revenueChart.destroy();
            const ctx3 = document.getElementById('revenueChart').getContext('2d');


            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'];
            const monthlyRevenue = months.map((month, index) => {
                const monthNum = index + 1;
                return bills
                    .filter(b => new Date(b.date).getMonth() + 1 === monthNum && b.status === 'Paid')
                    .reduce((sum, b) => sum + b.total, 0);
            });

            revenueChart = new Chart(ctx3, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: [{
                        label: 'Revenue ($)',
                        data: monthlyRevenue,
                        borderColor: '#2ecc71',
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

            const genderCount = {
                'Male': patients.filter(p => p.gender === 'Male').length,
                'Female': patients.filter(p => p.gender === 'Female').length,
                'Other': patients.filter(p => p.gender === 'Other').length
            };

            if (demographicsChart) demographicsChart.destroy();
            const ctx4 = document.getElementById('demographicsChart').getContext('2d');

            const hasGenderData = Object.values(genderCount).some(val => val > 0);

            demographicsChart = new Chart(ctx4, {
                type: 'pie',
                data: {
                    labels: hasGenderData ? Object.keys(genderCount).filter(key => genderCount[key] > 0) : ['No Data'],
                    datasets: [{
                        data: hasGenderData ? Object.values(genderCount).filter(val => val > 0) : [1],
                        backgroundColor: hasGenderData ? ['#3498db', '#e84393', '#95a5a6'] : ['#95a5a6']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }


        function setCurrentDate() {
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-US', options);
        }

        function updateDashboard() {
            document.getElementById('totalPatients').textContent = patients.length;
            document.getElementById('totalAppointments').textContent = appointments.length;
            document.getElementById('totalDoctors').textContent = doctors.length;
            document.getElementById('totalDepartments').textContent = departments.length;

            const today = new Date().toISOString().split('T')[0];
            const todayAppts = appointments.filter(a => a.date === today);

            const html = todayAppts.map(a => `
                <tr>
                    <td>${a.patient} ${a.emergency ? '<span class="badge-emergency">Emergency</span>' : ''}</td>
                    <td>${a.doctor}</td>
                    <td>${a.department}</td>
                    <td>${a.time}</td>
                    <td><span class="badge bg-${getStatusColor(a.status)}">${a.status}</span></td>
                </tr>
            `).join('');

            document.getElementById('todayAppointments').innerHTML = html || '<tr><td colspan="5" class="text-center">No appointments for today</td></tr>';
        }

        function renderPatients(searchTerm = '') {
            const filteredPatients = patients.filter(p =>
                p.name.toLowerCase().includes(searchTerm) ||
                (p.phone && p.phone.includes(searchTerm)) ||
                (p.email && p.email.toLowerCase().includes(searchTerm))
            );

            const html = filteredPatients.map(p => `
                <tr>
                    <td>${p.id}</td>
                    <td>${p.name}</td>
                    <td>${p.age}</td>
                    <td>${p.gender}</td>
                    <td>${p.phone}</td>
                    <td><span class="badge bg-danger">${p.bloodGroup}</span></td>
                    <td>${p.lastVisit}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" onclick="deletePatient(${p.id})">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            `).join('');

            document.getElementById('patientsTable').innerHTML = html || '<tr><td colspan="8" class="text-center">No patients added yet</td></tr>';
        }

        function renderAppointments() {
            const html = appointments.map(a => `
                <tr>
                    <td>${a.patient} ${a.emergency ? '<span class="badge-emergency">Emergency</span>' : ''}</td>
                    <td>${a.doctor}</td>
                    <td>${a.department}</td>
                    <td>${a.date}</td>
                    <td>${a.time}</td>
                    <td><span class="badge bg-${getStatusColor(a.status)}">${a.status}</span></td>
                    <td>
                        <select class="form-select form-select-sm" onchange="updateAppointmentStatus(${a.id}, this.value)" style="width: 130px;">
                            <option value="Scheduled" ${a.status === 'Scheduled' ? 'selected' : ''}>Scheduled</option>
                            <option value="In Progress" ${a.status === 'In Progress' ? 'selected' : ''}>In Progress</option>
                            <option value="Completed" ${a.status === 'Completed' ? 'selected' : ''}>Completed</option>
                            <option value="Cancelled" ${a.status === 'Cancelled' ? 'selected' : ''}>Cancelled</option>
                        </select>
                    </td>
                </tr>
            `).join('');

            document.getElementById('appointmentsTable').innerHTML = html || '<tr><td colspan="7" class="text-center">No appointments scheduled</td></tr>';
            updateStats();
        }

        function renderDoctors() {
            const html = doctors.map(d => `
                <div class="col-md-4">
                    <div class="doctor-card">
                        <div class="doctor-avatar">${d.name.split(' ').map(n => n[0]).join('')}</div>
