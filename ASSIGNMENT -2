<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hospital Management System</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .sidebar {
            background: linear-gradient(180deg, #1e3c72 0%, #2a5298 100%);
            min-height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            width: 250px;
            padding: 20px 0;
            box-shadow: 4px 0 10px rgba(0, 0, 0, 0.1);
            z-index: 1000;
            transition: width 0.3s ease-in-out;
        }

        .sidebar-logo {
            color: white;
            font-size: 24px;
            font-weight: bold;
            padding: 20px;
            text-align: center;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
            animation: fadeInDown 0.5s ease-out;
            cursor: pointer;
            transition: all 0.3s;
        }

        .sidebar-logo:hover {
            transform: scale(1.05);
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
        }

        .sidebar-menu li {
            margin: 5px 0;
            animation: slideInRight 0.4s ease-out forwards;
            opacity: 0;
            animation-delay: calc(0.1s * var(--item-index));
        }

        .sidebar-menu li:nth-child(1) {
            --item-index: 1;
        }

        .sidebar-menu li:nth-child(2) {
            --item-index: 2;
        }

        .sidebar-menu li:nth-child(3) {
            --item-index: 3;
        }

        .sidebar-menu li:nth-child(4) {
            --item-index: 4;
        }

        .sidebar-menu li:nth-child(5) {
            --item-index: 5;
        }

        .sidebar-menu a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            transition: all 0.3s;
        }

        .sidebar-menu a:hover,
        .sidebar-menu a.active {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border-left: 4px solid #4CAF50;
        }

        .sidebar-menu i {
            margin-right: 15px;
            font-size: 20px;
            width: 25px;
        }

        .main-content {
            margin-left: 250px;
            padding: 30px;
            transition: margin-left 0.3s ease-in-out;
        }

        .top-bar {
            background: white;
            padding: 20px 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: fadeInDown 0.6s ease-out;
        }

        .page-title {
            font-size: 28px;
            font-weight: bold;
            color: #333;
        }

        .stats-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s, box-shadow 0.3s;
            border-left: 5px solid;
            animation: fadeInUp 0.5s ease-out forwards;
            opacity: 0;
            animation-delay: calc(0.1s * var(--card-index));
        }

        .row>.col-md-3:nth-child(1) .stats-card {
            --card-index: 1;
        }

        .row>.col-md-3:nth-child(2) .stats-card {
            --card-index: 2;
        }

        .row>.col-md-3:nth-child(3) .stats-card {
            --card-index: 3;
        }

        .row>.col-md-3:nth-child(4) .stats-card {
            --card-index: 4;
        }

        .stats-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.15);
        }

        .stats-card.blue {
            border-left-color: #3498db;
        }

        .stats-card.green {
            border-left-color: #2ecc71;
        }

        .stats-card.orange {
            border-left-color: #e67e22;
        }

        .stats-card.purple {
            border-left-color: #9b59b6;
        }

        .stats-number {
            font-size: 36px;
            font-weight: bold;
            margin: 10px 0;
            transition: transform 0.2s;
        }

        .stats-card:hover .stats-number {
            transform: scale(1.05);
        }

        .stats-label {
            color: #7f8c8d;
            font-size: 14px;
            text-transform: uppercase;
        }

        .stats-icon {
            font-size: 50px;
            opacity: 0.2;
            float: right;
            transition: opacity 0.3s, transform 0.3s;
        }

        .stats-card:hover .stats-icon {
            opacity: 0.3;
            transform: rotate(5deg) scale(1.1);
        }

        .content-section {
            display: none;
        }

        .content-section.active {
            display: block;
            animation: fadeIn 0.5s ease-out;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.1);
        }

        .table-container {
            background: white;
            border-radius: 15px;
            padding: 25px;
            margin-top: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            animation: fadeInUp 0.7s ease-out;
        }

        .btn-custom {
            border-radius: 25px;
            padding: 10px 25px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-custom:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(0, 123, 255, 0.3);
        }

        .badge-status {
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 12px;
        }

        .modal-content {
            border-radius: 15px;
            animation: slideInUp 0.3s ease-out;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            padding: 12px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

        .search-box {
            position: relative;
        }

        .search-box input {
            padding-left: 45px;
            transition: width 0.3s;
        }

        .search-box input:focus {
            width: 110%;
        }

        .search-box i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #7f8c8d;
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 0;
                overflow: hidden;
            }

            .main-content {
                margin-left: 0;
            }

            .sidebar.mobile-open {
                width: 250px;
            }
        }

        .doctor-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s, box-shadow 0.3s;
            margin-bottom: 20px;
            animation: fadeInScale 0.5s ease-out;
        }

        .doctor-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        }

        .doctor-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 32px;
            font-weight: bold;
            margin: 0 auto 15px;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .doctor-card:hover .doctor-avatar {
            transform: scale(1.1) rotate(5deg);
            box-shadow: 0 8px 15px rgba(102, 126, 234, 0.4);
        }

        .department-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            transition: transform 0.3s, box-shadow 0.3s;
            animation: fadeInRight 0.6s ease-out;
        }

        .department-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 18px 30px rgba(0, 0, 0, 0.3);
        }

        .progress-custom {
            height: 10px;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-bar {
            transition: width 1s ease-in-out;
        }


        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes slideInUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        @keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }


        .table tbody tr {
            transition: background-color 0.2s, transform 0.2s;
        }

        .table tbody tr:hover {
            background-color: rgba(102, 126, 234, 0.05);
            transform: scale(1.005);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }


        .alert {
            animation: slideInDown 0.4s ease-out;
        }

        @keyframes slideInDown {
            from {
                transform: translate(-50%, -100%);
                opacity: 0;
            }

            to {
                transform: translate(-50%, 0);
                opacity: 1;
            }
        }


        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
        }

        .auth-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 450px;
            padding: 40px;
            animation: fadeInScale 0.6s ease-out;
        }

        .auth-card .nav-pills .nav-link {
            color: #666;
            font-weight: 600;
            padding: 12px;
            margin: 0 5px;
            border-radius: 10px;
        }

        .auth-card .nav-pills .nav-link.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .auth-form {
            margin-top: 30px;
        }

        .auth-form .form-control {
            border-radius: 12px;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            transition: all 0.3s;
        }

        .auth-form .form-control:focus {
            border-color: #667eea;
            box-shadow: none;
        }

        .auth-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            font-size: 16px;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .auth-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        /* Profile card styles */
        .profile-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }

        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
            font-weight: bold;
            margin: 0 auto 20px;
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
        }

        .profile-avatar:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .analytics-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            height: 100%;
        }

        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
        }


        .top-navbar {
            background: white;
            padding: 10px 20px;
            border-radius: 15px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-links {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .nav-link-item {
            color: #666;
            text-decoration: none;
            padding: 8px 15px;
            border-radius: 10px;
            transition: all 0.3s;
            font-weight: 500;
        }

        .nav-link-item:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateY(-2px);
        }

        .nav-link-item i {
            margin-right: 5px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .user-avatar:hover {
            transform: scale(1.1);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }


        .sidebar-menu a[data-section="profile"] {
            position: relative;
            overflow: hidden;
        }

        .sidebar-menu a[data-section="profile"]::after {
            content: '';
            position: absolute;
            top: 50%;
            right: 0;
            width: 0;
            height: 0;
            border-style: solid;
            border-width: 10px 10px 10px 0;
            border-color: transparent #4CAF50 transparent transparent;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .sidebar-menu a[data-section="profile"].active::after {
            opacity: 1;
        }


        #mainApp {
            display: none;
        }


        .badge-emergency {
            background-color: #dc3545;
            color: white;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            margin-left: 5px;
        }


        .emergency-checkbox {
            margin-top: 10px;
        }

        .emergency-checkbox .form-check-input:checked {
            background-color: #dc3545;
            border-color: #dc3545;
        }


        .storage-indicator {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: white;
            padding: 10px 15px;
            border-radius: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            font-size: 12px;
            color: #666;
            z-index: 9999;
            animation: fadeInUp 0.5s ease-out;
            cursor: pointer;
        }

        .storage-indicator i {
            color: #28a745;
            margin-right: 5px;
        }

        .storage-indicator:hover {
            transform: scale(1.05);
        }


        .persistent-message {
            color: #28a745;
            font-size: 12px;
            margin-top: 5px;
        }
    </style>
</head>

<body>
    <!-- ===== AUTHENTICATION CONTAINER (shown first) ===== -->
    <div id="authContainer" class="auth-container">
        <div class="auth-card">
            <div class="text-center mb-4">
                <i class="bi bi-heart-pulse-fill" style="font-size: 48px; color: #667eea;"></i>
                <h2 class="mt-3">Dharmik Hospital</h2>
                <p class="text-muted">Please login or register to continue</p>
            </div>

            <!-- Tab Navigation -->
            <ul class="nav nav-pills nav-justified mb-4" id="authTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="login-tab" data-bs-toggle="pill" data-bs-target="#login"
                        type="button" role="tab">Login</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="register-tab" data-bs-toggle="pill" data-bs-target="#register"
                        type="button" role="tab">Register</button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content" id="authTabsContent">
                <!-- Login Form -->
                <div class="tab-pane fade show active" id="login" role="tabpanel">
                    <form class="auth-form" id="loginForm" onsubmit="event.preventDefault(); handleLogin();">
                        <div class="mb-3">
                            <label class="form-label">Email address</label>
                            <input type="email" class="form-control" id="loginEmail" placeholder="Enter your email"
                                required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-control" id="loginPassword"
                                placeholder="Enter your password" required>
                        </div>
                        <button type="submit" class="btn btn-primary auth-btn w-100">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Login
                        </button>
                    </form>
                </div>

                <!-- Register Form -->
                <div class="tab-pane fade" id="register" role="tabpanel">
                    <form class="auth-form" id="registerForm" onsubmit="event.preventDefault(); handleRegister();">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="regName" placeholder="Enter your full name"
                                required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email address</label>
                            <input type="email" class="form-control" id="regEmail" placeholder="Enter your email"
                                required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-control" id="regPassword" placeholder="Create a password"
                                required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Confirm Password</label>
                            <input type="password" class="form-control" id="regConfirmPassword"
                                placeholder="Confirm your password" required>
                        </div>
                        <button type="submit" class="btn btn-primary auth-btn w-100">
                            <i class="bi bi-person-plus me-2"></i>Register
                        </button>
                    </form>
                </div>
            </div>

            <!-- Demo credentials hint -->
            <div class="text-center mt-4">
                <small class="text-muted">Demo: admin@hospital.com / admin123</small>
                <div class="persistent-message mt-2">
                    <i class="bi bi-database-check"></i> Your data is saved permanently in your browser
                </div>
            </div>
        </div>
    </div>


    <div id="mainApp">

        <div class="storage-indicator" onclick="showStorageInfo()" title="Click to see storage info">
            <i class="bi bi-database"></i> Data Saved Permanently
        </div>

        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-logo" onclick="goToHome()">
                <i class="bi bi-heart-pulse-fill"></i> Dharmik Hospital
            </div>
            <ul class="sidebar-menu">
                <li><a href="#" class="menu-link active" data-section="dashboard">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a></li>
                <li><a href="#" class="menu-link" data-section="patients">
                        <i class="bi bi-people-fill"></i> Patients
                    </a></li>
                <li><a href="#" class="menu-link" data-section="appointments">
                        <i class="bi bi-calendar-check"></i> Appointments
                    </a></li>
                <li><a href="#" class="menu-link" data-section="doctors">
                        <i class="bi bi-person-badge"></i> Doctors
                    </a></li>
                <li><a href="#" class="menu-link" data-section="departments">
                        <i class="bi bi-building"></i> Departments
                    </a></li>
                <li><a href="#" class="menu-link" data-section="billing">
                        <i class="bi bi-receipt"></i> Billing
                    </a></li>
                <li><a href="#" class="menu-link" data-section="analytics">
                        <i class="bi bi-graph-up"></i> Analytics
                    </a></li>
                <li><a href="#" class="menu-link" data-section="profile" id="profileMenuItem">
                        <i class="bi bi-person-circle"></i> Profile
                    </a></li>
                <li><a href="#" class="menu-link" onclick="logout()">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a></li>
            </ul>
        </div>


        <div class="main-content">

            <div class="top-navbar">
                <div class="nav-links">
                    <a href="#" class="nav-link-item" onclick="goToHome()">
                        <i class="bi bi-house-door"></i> Home
                    </a>
                    <a href="#" class="nav-link-item" data-section="dashboard">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="#" class="nav-link-item" data-section="patients">
                        <i class="bi bi-people"></i> Patients
                    </a>
                    <a href="#" class="nav-link-item" data-section="appointments">
                        <i class="bi bi-calendar"></i> Appointments
                    </a>
                    <a href="#" class="nav-link-item" data-section="analytics">
                        <i class="bi bi-graph-up"></i> Analytics
                    </a>
                </div>
                <div class="user-info">
                    <span id="navbarUserName">Admin User</span>
                    <div class="user-avatar" onclick="goToProfile()" id="navbarAvatar">A</div>
                </div>
            </div>

            <!-- Dashboard Section -->
            <div class="content-section active" id="dashboard">
                <div class="top-bar">
                    <h1 class="page-title">Dashboard</h1>
                    <div class="text-muted">
                        <i class="bi bi-calendar3"></i> <span id="currentDate"></span>
