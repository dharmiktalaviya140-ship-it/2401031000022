                            <i class="bi bi-trash"></i> Remove
                        </button>
                    </div>
                </div>
            `).join('');

            document.getElementById('doctorsGrid').innerHTML = html || '<div class="col-12 text-center">No doctors added yet</div>';
        }

        function renderDepartments() {
            const html = departments.map(d => {
                const occupancy = d.beds ? ((d.beds - d.availableBeds) / d.beds * 100).toFixed(0) : 0;
                return `
                    <div class="col-md-6">
                        <div class="department-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4>${d.name}</h4>
                                    <p class="mb-0">Head: ${d.head}</p>
                                </div>
                                <button class="btn btn-sm btn-light" onclick="deleteDepartment(${d.id})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
