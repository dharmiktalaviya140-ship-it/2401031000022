                                <div class="d-flex justify-content-between mb-1">
                                    <small>Occupancy</small>
                                    <small>${occupancy}%</small>
                                </div>
                                <div class="progress progress-custom">
                                    <div class="progress-bar bg-light" style="width: ${occupancy}%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('departmentsGrid').innerHTML = html || '<div class="col-12 text-center">No departments added yet</div>';
        }

        function updateStats() {
            document.getElementById('scheduledCount').textContent = appointments.filter(a => a.status === 'Scheduled').length;
            document.getElementById('inProgressCount').textContent = appointments.filter(a => a.status === 'In Progress').length;
            document.getElementById('completedCount').textContent = appointments.filter(a => a.status === 'Completed').length;
            document.getElementById('cancelledCount').textContent = appointments.filter(a => a.status === 'Cancelled').length;
        }

        function populateDropdowns() {
            const doctorSelect = document.getElementById('appointmentDoctor');
            if (doctorSelect) {
                doctorSelect.innerHTML = '<option value="">Select Doctor</option>' +
                    (doctors.length > 0 ? doctors.map(d => `<option value="${d.name}">${d.name}</option>`).join('') : '<option value="" disabled>No doctors available</option>');
            }

            const deptOptions = departments.map(d => `<option value="${d.name}">${d.name}</option>`).join('');
            const deptSelect1 = document.getElementById('appointmentDepartment');
            const deptSelect2 = document.getElementById('doctorDepartment');
            if (deptSelect1) deptSelect1.innerHTML = '<option value="">Select Department</option>' + (deptOptions || '<option value="" disabled>No departments available</option>');
            if (deptSelect2) deptSelect2.innerHTML = '<option value="">Select Department</option>' + (deptOptions || '<option value="" disabled>No departments available</option>');
        }

        function getStatusColor(status) {
            const colors = {
                'Scheduled': 'primary',
                'In Progress': 'warning',
                'Completed': 'success',
                'Cancelled': 'danger'
            };
            return colors[status] || 'secondary';
        }


        function openPatientModal() {
            document.getElementById('patientForm').reset();
            populateDoctorDropdownForPatient();
        }

        function savePatient() {
            const patient = {
                id: patients.length + 1,
                name: document.getElementById('patientName').value,
                age: parseInt(document.getElementById('patientAge').value),
                gender: document.getElementById('patientGender').value,
                phone: document.getElementById('patientPhone').value,
                email: document.getElementById('patientEmail').value,
                bloodGroup: document.getElementById('patientBlood').value,
                condition: document.getElementById('patientCondition').value,
                address: document.getElementById('patientAddress').value,
                lastVisit: new Date().toISOString().split('T')[0],
                assignedDoctor: document.getElementById('patientDoctor').value
            };

            patients.push(patient);
            renderPatients();
            updateDashboard();
            populatePatientDropdown();
            populateAppointmentPatientDropdown();


            saveToLocalStorage();

            bootstrap.Modal.getInstance(document.getElementById('patientModal')).hide();
            showAlert('Patient added successfully!', 'success');
        }

        function deletePatient(id) {
            if (confirm('Are you sure you want to delete this patient?')) {
                patients = patients.filter(p => p.id !== id);
                renderPatients();
                updateDashboard();
                populatePatientDropdown();
                populateAppointmentPatientDropdown();


                saveToLocalStorage();

                showAlert('Patient deleted successfully!', 'success');
            }
        }


        function openAppointmentModal() {
            document.getElementById('appointmentForm').reset();
            populateAppointmentPatientDropdown();
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('appointmentDate').value = today;
        }

        function saveAppointment() {
            const emergency = document.getElementById('appointmentEmergency').checked;

            const appointment = {
                id: appointments.length + 1,
                patient: document.getElementById('appointmentPatient').value,
                doctor: document.getElementById('appointmentDoctor').value,
                department: document.getElementById('appointmentDepartment').value,
                date: document.getElementById('appointmentDate').value,
                time: document.getElementById('appointmentTime').value,
                status: 'Scheduled',
                reason: document.getElementById('appointmentReason').value,
                emergency: emergency
            };

            if (!appointment.patient || !appointment.doctor || !appointment.department || !appointment.date || !appointment.time) {
                showAlert('Please fill all required fields', 'danger');
                return;
            }

            appointments.push(appointment);
            renderAppointments();
            updateDashboard();


            saveToLocalStorage();

            bootstrap.Modal.getInstance(document.getElementById('appointmentModal')).hide();
            showAlert('Appointment scheduled successfully!', 'success');
        }

        function updateAppointmentStatus(id, status) {
            const appointment = appointments.find(a => a.id === id);
            if (appointment) {
                appointment.status = status;
                renderAppointments();


                saveToLocalStorage();

                showAlert('Appointment status updated!', 'success');
            }
        }


        function openDoctorModal() {
            document.getElementById('doctorForm').reset();
        }

        function saveDoctor() {
            const doctor = {
                id: doctors.length + 1,
                name: document.getElementById('doctorName').value,
                specialization: document.getElementById('doctorSpecialization').value,
                department: document.getElementById('doctorDepartment').value,
                experience: parseInt(document.getElementById('doctorExperience').value),
                phone: document.getElementById('doctorPhone').value,
                email: document.getElementById('doctorEmail').value,
                qualification: document.getElementById('doctorQualification').value
            };

            doctors.push(doctor);
            renderDoctors();
            updateDashboard();
            populateDropdowns();
            populateDoctorDropdownForPatient();


            saveToLocalStorage();

            showAlert('Doctor added successfully!', 'success');
        }

        function deleteDoctor(id) {
            if (confirm('Are you sure you want to delete this doctor?')) {
                doctors = doctors.filter(d => d.id !== id);
                renderDoctors();
                updateDashboard();
                populateDropdowns();
                populateDoctorDropdownForPatient();


                saveToLocalStorage();

                showAlert('Doctor deleted successfully!', 'success');
            }
        }


        function openDepartmentModal() {
            document.getElementById('departmentForm').reset();
        }

        function saveDepartment() {
            const department = {
                id: departments.length + 1,
                name: document.getElementById('departmentName').value,
                description: document.getElementById('departmentDescription').value,
                head: document.getElementById('departmentHead').value,
                beds: parseInt(document.getElementById('departmentBeds').value),
                availableBeds: parseInt(document.getElementById('departmentAvailableBeds').value)
            };

            departments.push(department);
            renderDepartments();
            updateDashboard();
            populateDropdowns();


            saveToLocalStorage();

            bootstrap.Modal.getInstance(document.getElementById('departmentModal')).hide();
            showAlert('Department added successfully!', 'success');
        }

        function deleteDepartment(id) {
            if (confirm('Are you sure you want to delete this department?')) {
                departments = departments.filter(d => d.id !== id);
                renderDepartments();
                updateDashboard();
                populateDropdowns();


                saveToLocalStorage();

                showAlert('Department deleted successfully!', 'success');
            }
        }


        function populatePatientDropdown() {
            const select = document.getElementById('billPatient');
            if (select) {
                select.innerHTML = '<option value="">Select Patient</option>' +
                    (patients.length > 0 ? patients.map(p => `<option value="${p.name}">${p.name}</option>`).join('') : '<option value="" disabled>No patients available</option>');
            }
        }

        function renderBills() {
            const tbody = document.getElementById('billingTableBody');
            if (!tbody) return;
            const html = bills.map(b => `
                <tr>
                    <td>#${b.id}</td>
                    <td>${b.patient}</td>
                    <td>${b.date}</td>
                    <td>${b.items}</td>
                    <td>$${b.total}</td>
                    <td><span class="badge bg-${b.status === 'Paid' ? 'success' : (b.status === 'Pending' ? 'warning' : 'danger')}">${b.status}</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="saveBillToFile(${b.id})">
                            <i class="bi bi-download"></i> Save
                        </button>
                    </td>
                </tr>
            `).join('');
            tbody.innerHTML = html || '<tr><td colspan="7" class="text-center">No bills generated</td></tr>';
        }

        function saveBill() {
            const patient = document.getElementById('billPatient').value;
            const date = document.getElementById('billDate').value;
            const items = document.getElementById('billItems').value;
            const amount = parseFloat(document.getElementById('billAmount').value) || 0;
            const status = document.getElementById('billStatus').value;

            if (!patient || !date || !items || !amount) {
                showAlert('Please fill all fields', 'danger');
                return;
            }

            const newBill = {
                id: bills.length + 1,
                patient: patient,
                date: date,
                items: items,
                total: amount,
                status: status
            };
            bills.push(newBill);
            renderBills();



            bootstrap.Modal.getInstance(document.getElementById('billingModal')).hide();
            document.getElementById('billingForm').reset();
            showAlert('Bill generated successfully!', 'success');
        }

        function saveBillToFile(billId) {
            const bill = bills.find(b => b.id === billId);
            if (!bill) return;

            const content = `
LJ HOSPITAL BILL
================
Bill ID: #${bill.id}
Patient: ${bill.patient}
Date: ${bill.date}
Items: ${bill.items}
Total Amount: $${bill.total}
Status: ${bill.status}
================
Thank you for choosing Dharmik Hospital.
            `.trim();

            const blob = new Blob([content], { type: 'text/plain' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `bill_${bill.id}_${bill.patient.replace(/\s/g, '_')}.txt`;
            link.click();
            URL.revokeObjectURL(link.href);

            showAlert('Bill saved as text file', 'success');
        }


        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
            alertDiv.style.zIndex = '9999';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);

            setTimeout(() => {
                alertDiv.remove();
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('authContainer').style.display = 'flex';
            document.getElementById('mainApp').style.display = 'none';

            initializeDefaultData();
        });
    </script>
</body>

</html>
