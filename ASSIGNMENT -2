                            <div class="row text-center mb-3">
                                <div class="col-6">
                                    <h5>${d.beds || 0}</h5>
                                    <small>Total Beds</small>
                                </div>
                                <div class="col-6">
                                    <h5>${d.availableBeds || 0}</h5>
                                    <small>Available</small>
                                </div>
